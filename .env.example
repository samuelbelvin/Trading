APP_ENV=development
TRADING_MODE=paper

# Execution routing
FOREX_EXECUTION_BROKER=oanda
STOCK_EXECUTION_BROKER=alpaca
CRYPTO_EXECUTION_BROKER=alpaca

# Risk
MAX_RISK_PER_TRADE_PCT=0.005
MAX_DAILY_LOSS_PCT=0.02
MAX_OPEN_POSITIONS=5
DEFAULT_ORDER_SIZE_USD=1000
KILL_SWITCH=false

# Symbols
STOCK_SYMBOLS=AAPL,NVDA,TSLA,AMD,META,MSFT
FOREX_SYMBOLS=EUR_USD,GBP_USD,USD_JPY
CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD

# Polling / data
POLL_SECONDS=30

# Optional Polygon stock scanner support
POLYGON_API_KEY=

# Alpaca stocks + crypto
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# OANDA forex
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
